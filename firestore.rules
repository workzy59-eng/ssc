rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId} (matches Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - role: string (client | pro) (required)
    //   - category: string (optional)
    //   - bio: string (optional)
    //   - location: string (optional)
    //   - rating: number (optional)
    //   - reviewCount: number (optional)
    //   - createdAt: timestamp (required)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['client', 'pro'] &&
             data.createdAt is timestamp &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 2000)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() < 1000)) &&
             (!('category' in data) || (data.category is string && data.category.size() < 50)) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() < 20));
    }

    function isAdmin() {
      return isAuthenticated() && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
              (request.auth.token.email == "workzy59@gmail.com" && request.auth.token.email_verified == true));
    }

    function isChatParticipant(chatId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['id', 'participants', 'updatedAt']) &&
             data.id is string &&
             data.participants is list &&
             data.participants.size() == 2 &&
             data.updatedAt is timestamp &&
             (!('lastMessage' in data) || (data.lastMessage is string && data.lastMessage.size() < 1000)) &&
             (!('lastMessageAt' in data) || (data.lastMessageAt is timestamp));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'text', 'createdAt']) &&
             data.senderId is string &&
             data.text is string && data.text.size() > 0 && data.text.size() < 5000 &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && 
                      isValidUser(request.resource.data) &&
                      request.resource.data.role == resource.data.role &&
                      request.resource.data.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (resource == null || request.auth.uid in resource.data.participants);
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants && isValidChat(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants && 
                      isValidChat(request.resource.data) &&
                      request.resource.data.participants == resource.data.participants &&
                      request.resource.data.id == resource.data.id;
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isChatParticipant(chatId);
      allow create: if isChatParticipant(chatId) && 
                      request.resource.data.senderId == request.auth.uid &&
                      isValidMessage(request.resource.data);
    }

    match /test/connection {
      allow read: if isAuthenticated();
    }
  }
}
