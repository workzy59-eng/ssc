{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores information about both clients and service professionals.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "pro"] },
        "category": { "type": "string", "description": "Service category (e.g., Plumber, Electrician) if role is pro" },
        "bio": { "type": "string" },
        "location": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "ChatRoom": {
      "title": "Chat Room",
      "description": "Represents a conversation between two users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a chat room.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/chats/{chatId}": {
      "schema": "ChatRoom",
      "description": "Collection of chat rooms."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Subcollection of messages in a chat room."
    }
  }
}
